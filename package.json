{
  "name": "starter3000",
  "homepage": "https://github.com/ezekielaquino/Starter3000",
  "author": "Ezekiel Aquino (https://ezekielaquino.com)",
  "license": "MIT",
  "version": "0.0.3",
  "bin": {
    "starter3000": "./npx.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "husky install",
    "format": "prettier --write .",
    "lint": "eslint --fix",
    "postinstall": "yarn prepare",
    "pre-commit": "lint-staged && yarn tsc"
  },
  "dependencies": {
    "@emotion/css": "^11.1.3",
    "@emotion/react": "^11.4.1",
    "@emotion/styled": "^11.3.0",
    "next": "^11.1.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.15.0",
    "@emotion/babel-plugin": "^11.3.0",
    "@svgr/webpack": "^5.5.0",
    "@types/react": "^17.0.19",
    "eslint": "^7.32.0",
    "eslint-config-next": "11.1.0",
    "husky": "^7.0.2",
    "lint-staged": "^11.1.2",
    "prettier": "^2.3.2",
    "typescript": "^4.4.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md,mdx}": [
      "yarn format"
    ]
  },
  "ignore": [
    "node_modules",
    ".next"
  ]
}
